generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mysql"
}

model Barbershop {
  id             String        @id @default(uuid())
  name           String?
  phone          String?
  address        String?
  businessHours  Json?
  
  planStatus     String        @default("TRIAL") // "TRIAL", "ACTIVE", "PAST_DUE"
  trialExpiresAt DateTime      
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  appointments   Appointment[]
  services       Service[]
  users          User[]

  @@map("barbershops")
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  role         String        @default("OWNER") // Pode ser "OWNER" ou "BARBER"
  createdAt    DateTime      @default(now())
  barbershopId String
  
  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointments Appointment[] // <-- NOVA RELAÇÃO AQUI

  @@index([barbershopId], map: "users_barbershopId_fkey")
  @@map("users")
}

model Appointment {
  id           Int         @id @default(autoincrement())
  clientName   String
  date         String
  time         String
  status       String      @default("CONFIRMED")
  barbershopId String
  barberId     String?     // <-- NOVO CAMPO (Quem vai atender)
  createdAt    DateTime    @default(now())
  
  barbershop   Barbershop  @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barber       User?       @relation(fields: [barberId], references: [id], onDelete: SetNull) // <-- RELAÇÃO
  services     Service[]   @relation("AppointmentServices")

  @@index([barbershopId], map: "appointments_barbershopId_fkey")
  @@index([barberId], map: "appointments_barberId_fkey") // <-- ÍNDICE PARA PERFORMANCE
  @@map("appointments")
}

model Service {
  id           String        @id @default(uuid())
  name         String
  price        Float
  duration     Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  barbershopId String
  
  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointments Appointment[] @relation("AppointmentServices")

  @@index([barbershopId], map: "services_barbershopId_fkey")
  @@map("services")
}