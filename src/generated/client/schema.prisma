generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mysql"
}

model Barbershop {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
  users        User[]

  @@map("barbershops")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("OWNER")
  createdAt DateTime @default(now())

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Appointment {
  id         Int    @id @default(autoincrement())
  clientName String
  service    String
  price      Float
  date       String // Formato: "YYYY-MM-DD"
  time       String // Formato: "09:00 - 09:40"
  status     String @default("CONFIRMED") // Pode ser CONFIRMED, CANCELED, etc.

  createdAt DateTime @default(now())

  // Relação com a Barbearia (O coração do SaaS multi-tenant)
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@map("appointments")
}
